# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (for pod/project name generation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Owner accounts (comma-separated emails that auto-get owner role)
OWNER_EMAILS=hq@theupskillinglabs.org,brendan@withlevy.com

# Resend (email delivery for magic link invitations)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@enroll.theupskillinglabs.org

# Public app URL (used to build magic links in emails)
NEXT_PUBLIC_APP_URL=https://app.theupskillinglabs.org

# Slack integration (issue #189). All three are required for the Slack features
# (DM reminders, /learninglog slash command, membership + intro verification).
# Absent SLACK_BOT_TOKEN makes every Slack path a quiet no-op (reminders still
# email, verification skips) — see lib/integrations/slack.ts `slackEnabled()`.
# SLACK_BOT_TOKEN=xoxb-...                 # Bot User OAuth Token
# SLACK_SIGNING_SECRET=...                 # verifies inbound slash-command/interactivity requests
# SLACK_INTRO_CHANNEL_ID=C0XXXXXXX         # the #intros channel the bot scans for intro posts
# NEXT_PUBLIC_SLACK_INVITE_URL=            # optional: workspace invite link for the onboarding checklist CTA

# Other external integrations (Week 2+)
# GITHUB_TOKEN=
# GOOGLE_SERVICE_ACCOUNT=

# Entity Explorer (read-only admin entity browser). Single flag, default OFF:
# the route 404s and the nav link is hidden unless this is exactly "true".
# ENTITY_EXPLORER_ENABLED=true
