{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm run build)",
      "Bash(npm run check:migrations)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx eslint:*)",
      "Bash(npx vitest:*)",
      "Bash(node scripts/check-migration-numbers.mjs)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)"
    ]
  },
  "hooks": {
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node scripts/check-migration-numbers.mjs || exit 2"
          }
        ]
      }
    ]
  }
}
