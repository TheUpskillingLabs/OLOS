# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env*.local
!.env.local.example

# MCP server config — may contain credentials
.mcp.json

# supabase
supabase/.temp/
supabase/.branches/

# legacy migration — workbook contains PII, never commit
docs/Upskiller Community Manager*.xlsx
docs/Upskiller Community Manager*.csv

# Office docs may contain credentials/PII — never commit
*.docx
*.doc
*.xlsx
*.xls
*.pptx
*.ppt

# migration script venv + run logs
scripts/migration/.venv/
scripts/migration/run_*.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local dev scripts (untracked utilities)
scripts/dev/
